# ==== Đặt các biến này trong Vercel > Project > Settings > Environment Variables ====
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/edubank?retryWrites=true&w=majority
JWT_SECRET=chuoi-bi-mat-dai-va-ngau-nhien
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI nhập đề từ PDF/ảnh (qua OpenRouter — https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
# Model tùy chọn, mặc định google/gemini-2.5-flash (rẻ, OCR tốt). Ví dụ khác: anthropic/claude-sonnet-4.5
OPENROUTER_MODEL=google/gemini-2.5-flash
